@using TestRunner.Web.Services
@using TestRunner.Web.Models

@page "/run-tests"
@rendermode InteractiveServer
@inject IJSRuntime JS

<style>
    .section-label {
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--bs-secondary-color);
        margin-bottom: 0.6rem;
    }

    .config-section {
        border: 1px solid var(--bs-border-color);
        border-radius: 0.5rem;
        padding: 1rem 1.25rem 1.25rem;
        margin-bottom: 1rem;
    }

    .dropdowns-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 1rem;
    }

    .toggles-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
    }

    .toggle-item {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        min-width: 110px;
    }

    .toggle-item .toggle-label {
        font-size: 0.875rem;
        font-weight: 500;
    }

    .coming-soon-badge {
        margin-left: 0.4rem;
        font-size: 0.65rem;
        padding: 1px 5px;
        border-radius: 20px;
        background: rgba(255, 193, 7, 0.15);
        color: #ffc107;
        border: 1px solid rgba(255, 193, 7, 0.3);
        white-space: nowrap;
        vertical-align: middle;
    }

    .mfa-toggle-wrapper {
        opacity: 0.45;
        cursor: not-allowed;
    }

    .mfa-toggle-wrapper .form-check-input {
        cursor: not-allowed;
    }

    .output-panel {
        font-family: 'Cascadia Code', 'Fira Code', 'Consolas', monospace;
        font-size: 0.8rem;
        overflow-y: auto;
        white-space: pre-wrap;
        word-break: break-all;
        flex: 1;
        min-height: 300px;
    }

    .output-wrapper {
        display: flex;
        flex-direction: column;
        height: calc(100vh - var(--output-top, 500px) - 2rem);
        min-height: 300px;
    }

    .action-bar {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .custom-tag-row {
        overflow: hidden;
        animation: slideDown 0.2s ease-out;
    }

    .warning-row {
        animation: slideDown 0.2s ease-out;
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .help-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 15px;
        height: 15px;
        border-radius: 50%;
        background: var(--bs-secondary-bg, #6c757d);
        color: var(--bs-body-bg, #fff);
        font-size: 0.6rem;
        font-weight: 700;
        cursor: help;
        margin-left: 0.3rem;
        vertical-align: middle;
        opacity: 0.6;
        transition: opacity 0.15s;
        position: relative;
        top: -1px;
        text-decoration: none;
    }

    .help-icon:hover {
        opacity: 1;
    }

    @@media (max-width: 600px) {
        .dropdowns-grid {
            grid-template-columns: 1fr;
        }

        .toggles-grid {
            gap: 1rem;
        }
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Run Automated Tests</h3>
</div>

<div class="config-section">
    <div class="section-label">Configuration</div>

    <div class="dropdowns-grid">

        <div>
            <label class="form-label fw-semibold">Your Name <span class="text-danger">*</span></label>
            <input type="text"
                   class="form-control @(ShowValidation && string.IsNullOrWhiteSpace(RunnerName) ? "is-invalid" : "")"
                   @bind="RunnerName" placeholder="Enter your name" />
            @if (ShowValidation && string.IsNullOrWhiteSpace(RunnerName))
            {
                <div class="invalid-feedback">Name is required.</div>
            }
        </div>

        <div>
            <label class="form-label fw-semibold">
                Browser
                <span class="help-icon" data-bs-toggle="tooltip" data-bs-placement="top"
                      data-bs-title="The browser to run tests in.<br><br><b>Chromium:</b> recommended for broadest compatibility.<br><b>Firefox:</b> useful for cross-browser coverage. Does not support mobile emulation.<br><b>WebKit:</b> Safari's rendering engine, useful for iOS-style testing.">?</span>
            </label>
            <select class="form-select" @bind="SelectedBrowser" @bind:after="OnLayoutChanged">
                @foreach (var browser in Browsers)
                {
                    <option value="@browser">@browser</option>
                }
            </select>
        </div>

        <div>
            <label class="form-label fw-semibold">
                Device
                <span class="help-icon" data-bs-toggle="tooltip" data-bs-placement="top"
                      data-bs-title="Sets the viewport size and device emulation.<br><b>Desktop:</b> 1920×1080.<br><b>Mobile:</b> 375×812 (touch).<br><b>TabletVer:</b> 768×1024.<br><b>TabletHor:</b> 1024×768.<br><b>Custom:</b> enter your own resolution.">?</span>
            </label>
            <select class="form-select" @bind="SelectedDevice" @bind:after="OnLayoutChanged">
                @foreach (var device in Devices)
                {
                    <option value="@device">@device</option>
                }
            </select>
        </div>

        @if (SelectedDevice == "Custom")
        {
            <div class="custom-tag-row">
                <label class="form-label fw-semibold">
                    Resolution
                    <span class="help-icon" data-bs-toggle="tooltip" data-bs-placement="top"
                          data-bs-title="Enter a custom viewport size in WIDTHxHEIGHT format, e.g. 2560x1440.">?</span>
                </label>
                <input type="text" class="form-control" @bind="CustomResolution" placeholder="e.g. 2560x1440" />
            </div>
        }

        <div>
            <label class="form-label fw-semibold">
                Environment
                <span class="help-icon" data-bs-toggle="tooltip" data-bs-placement="top"
                      data-bs-title="The target environment to run tests against. Each environment points to a different URL defined in the test project's appsettings.json.">?</span>
            </label>
            <select class="form-select" @bind="SelectedEnvironment">
                @foreach (var env in Environments)
                {
                    <option value="@env">@env</option>
                }
            </select>
        </div>

        <div>
            <label class="form-label fw-semibold">
                Suite
                <span class="help-icon" data-bs-toggle="tooltip" data-bs-placement="top"
                      data-bs-title="The test suite to run.<br><b>Smoke:</b> core critical path tests.<br><b>Regression:</b> broader coverage.<br><b>Full:</b> everything.<br><b>Custom:</b> enter your own tag name below.">?</span>
            </label>
            <select class="form-select" @bind="SelectedSuite" @bind:after="OnLayoutChanged">
                @foreach (var suite in Suites)
                {
                    <option value="@suite">@suite</option>
                }
            </select>
        </div>

    </div>

    @if (SelectedSuite == "Custom")
    {
        <div class="mt-3 custom-tag-row">
            <label class="form-label fw-semibold">
                Custom Tag
                <span class="help-icon" data-bs-toggle="tooltip" data-bs-placement="top"
                      data-bs-title="Tag names are case sensitive and must match exactly as defined in your feature files (e.g. Smoke not smoke). To run multiple tags separate them with a comma, e.g. Smoke, Login.">?</span>
            </label>
            <input type="text"
                   class="form-control @(ShowValidation && string.IsNullOrWhiteSpace(CustomTag) ? "is-invalid" : "")"
                   style="max-width: 400px;" @bind="CustomTag" placeholder="e.g. Login or Smoke, Login" />
            @if (ShowValidation && string.IsNullOrWhiteSpace(CustomTag))
            {
                <div class="invalid-feedback">Tag required.</div>
            }
        </div>
    }

</div>

<div class="config-section">
    <div class="section-label">Options</div>
    <div class="toggles-grid">

        <div class="toggle-item">
            <span class="toggle-label">
                Headed
                <span class="help-icon" data-bs-toggle="tooltip" data-bs-placement="top"
                      data-bs-title="<b>Headed:</b> opens a visible browser window so you can watch the tests run in real time.<br><br><b>Headless:</b> runs in the background with no browser window — faster and suitable for CI.">?</span>
            </span>
            <div class="form-check form-switch mb-0">
                <input class="form-check-input" type="checkbox" role="switch" id="headedSwitch"
                       @bind="SelectedHeaded" />
                <label class="form-check-label" for="headedSwitch">
                    @(SelectedHeaded ? "Headed" : "Headless")
                </label>
            </div>
        </div>

        <div class="toggle-item">
            <span class="toggle-label">
                Record Video
                <span class="help-icon" data-bs-toggle="tooltip" data-bs-placement="top"
                      data-bs-title="<b>Disabled:</b> video is only saved if a test fails.<br><br><b>Enabled:</b> video is saved for every scenario regardless of outcome.">?</span>
            </span>
            <div class="form-check form-switch mb-0">
                <input class="form-check-input" type="checkbox" role="switch" id="videoSwitch" @bind="RecordVideo" />
                <label class="form-check-label" for="videoSwitch">
                    @(RecordVideo ? "Enabled" : "Disabled")
                </label>
            </div>
        </div>

        <div class="toggle-item">
            <span class="toggle-label">
                Record Traces
                <span class="help-icon" data-bs-toggle="tooltip" data-bs-placement="top"
                      data-bs-title="<b>Disabled:</b> traces are only saved if a test fails.<br><br><b>Enabled:</b> traces are saved for every scenario. Traces capture screenshots, network requests and DOM snapshots — useful for deep diagnostics but generates larger files.">?</span>
            </span>
            <div class="form-check form-switch mb-0">
                <input class="form-check-input" type="checkbox" role="switch" id="tracesSwitch" @bind="RecordTraces" />
                <label class="form-check-label" for="tracesSwitch">
                    @(RecordTraces ? "Enabled" : "Disabled")
                </label>
            </div>
        </div>

        <div class="toggle-item">
            <span class="toggle-label">
                MFA
                <span class="coming-soon-badge">Coming soon</span>
            </span>
            <div class="mfa-toggle-wrapper" title="MFA via Twilio — coming soon">
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" role="switch" id="mfaSwitch" disabled />
                    <label class="form-check-label text-muted" for="mfaSwitch">Disabled</label>
                </div>
            </div>
        </div>

    </div>
</div>

@if (ConfigurationWarning != null)
{
    <div class="alert alert-warning d-flex align-items-center gap-2 py-2 mb-3 warning-row" role="alert">
        <span>⚠️</span>
        <span>@ConfigurationWarning</span>
    </div>
}

<div class="action-bar mb-3">
    <button class="btn btn-primary" @onclick="RunTestsAsync" disabled="@(IsRunning || ConfigurationWarning != null)">
        @if (IsRunning)
        {
            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
            <span>Running...</span>
        }
        else
        {
            <span>▶ Run Tests</span>
        }
    </button>

    <button class="btn btn-danger" @onclick="StopTests" disabled="@(!IsRunning)">
        ⏹ Stop
    </button>

    @if (!string.IsNullOrEmpty(LastReportFileName))
    {
        <a href="/reports/view/@LastReportFileName" target="_blank" class="btn btn-outline-success">
            📊 View Report
        </a>
    }
</div>

<div class="output-wrapper" id="output-wrapper">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <span class="section-label mb-0">Output</span>
        @if (OutputLines.Count > 0)
        {
            <small class="text-muted">@OutputLines.Count lines</small>
        }
    </div>
    <pre id="output-panel" class="output-panel bg-dark text-light p-3 rounded">@string.Join("\n", OutputLines)</pre>
</div>

@code {
    private List<string> Browsers = new() { "chromium", "firefox", "webkit" };
    private List<string> Devices = new() { "Desktop", "Mobile", "TabletVer", "TabletHor", "Custom" };
    private List<string> Environments = new() { "REL", "QA2", "DEV" };
    private List<string> Suites = new() { "Smoke", "Regression", "Full", "Custom" };

    private string RunnerName = "";
    private string SelectedBrowser = "chromium";
    private string SelectedDevice = "Desktop";
    private string SelectedEnvironment = "REL";
    private string SelectedSuite = "Smoke";
    private bool SelectedHeaded = false;
    private bool RecordVideo = false;
    private bool RecordTraces = false;
    private string CustomResolution = "";
    private string CustomTag = "";

    private readonly List<string> OutputLines = new();
    private const int MaxLines = 2000;
    private bool IsRunning = false;
    private bool ShowValidation = false;
    private string? LastReportFileName = null;

    [Inject] private ITestRunnerService TestRunnerService { get; set; } = default!;
    private CancellationTokenSource? cts;

    private string? ConfigurationWarning => (SelectedBrowser, SelectedDevice) switch
    {
        ("firefox", "Mobile") => "Firefox does not support mobile emulation. Please select Desktop or switch to Chromium/WebKit.",
        ("firefox", "TabletVer") => "Firefox does not support tablet emulation. Please select Desktop or switch to Chromium/WebKit.",
        ("firefox", "TabletHor") => "Firefox does not support tablet emulation. Please select Desktop or switch to Chromium/WebKit.",
        _ => null
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var saved = await JS.InvokeAsync<string?>("localStorage.getItem", "prat-runner-name");
            if (!string.IsNullOrWhiteSpace(saved))
            {
                RunnerName = saved;
                await InvokeAsync(StateHasChanged);
            }

            await JS.InvokeVoidAsync("setOutputTop");
        }

        // Reinitialise tooltips on every render so dynamically shown
        // elements (Custom tag row, Resolution row) also get tooltips
        await JS.InvokeVoidAsync("initTooltips");
    }

    private async Task OnLayoutChanged()
    {
        await Task.Yield();
        await JS.InvokeVoidAsync("setOutputTop");
    }

    private async Task RunTestsAsync()
    {
        ShowValidation = true;

        if (string.IsNullOrWhiteSpace(RunnerName))
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (SelectedSuite == "Custom" && string.IsNullOrWhiteSpace(CustomTag))
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (ConfigurationWarning != null)
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        await JS.InvokeVoidAsync("localStorage.setItem", "prat-runner-name", RunnerName.Trim());

        IsRunning = true;
        LastReportFileName = null;
        OutputLines.Clear();
        cts = new CancellationTokenSource();

        var effectiveTag = SelectedSuite == "Custom"
            ? CustomTag.Trim().TrimStart('@')
            : SelectedSuite;

        var request = new TestRunRequest(
            SelectedBrowser,
            SelectedDevice,
            SelectedEnvironment,
            effectiveTag,
            SelectedHeaded,
            RecordVideo,
            RecordTraces,
            RunnerName.Trim(),
            CustomResolution: string.IsNullOrWhiteSpace(CustomResolution) ? null : CustomResolution,
            CustomTag: SelectedSuite == "Custom" ? effectiveTag : null
        );

        try
        {
            await foreach (var line in TestRunnerService.RunTestsAsync(request, cts.Token))
            {
                if (line.StartsWith("REPORT:"))
                {
                    LastReportFileName = line["REPORT:".Length..];
                    continue;
                }

                OutputLines.Add(line);
                if (OutputLines.Count > MaxLines)
                    OutputLines.RemoveAt(0);
                await InvokeAsync(StateHasChanged);
                await JS.InvokeVoidAsync("scrollToBottom", "output-panel");
                await Task.Yield();
            }
        }
        catch (OperationCanceledException)
        {
            OutputLines.Add("--- Test run cancelled ---");
        }
        catch (Exception ex)
        {
            OutputLines.Add($"[ERROR] {ex.Message}");
        }
        finally
        {
            IsRunning = false;
            cts?.Dispose();
            cts = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void StopTests()
    {
        cts?.Cancel();
    }
}
