@using TestRunner.Web.Services
@using TestRunner.Web.Models

@page "/run-tests"
@rendermode InteractiveServer

@inject IJSRuntime JS

<h3 class="mb-3">Run Automated Tests</h3>

<div class="row g-3">

    <div class="col-md-3">
        <label class="form-label">Browser</label>
        <select class="form-select" @bind="SelectedBrowser">
            @foreach (var browser in Browsers)
            {
                <option value="@browser">@browser</option>
            }
        </select>
    </div>

    @* <div class="col-md-3">
        <label class="form-label">Headed</label>
        <select class="form-select" @bind="SelectedHeaded">
            @foreach (var headed in Headed)
            {
                <option value="@headed">@headed</option>
            }
        </select>
    </div> *@

    <div class="col-md-3">
        <label class="form-label">Device</label>
        <select class="form-select" @bind="SelectedDevice">
            @foreach (var device in Devices)
            {
                <option value="@device">@device</option>
            }
        </select>
    </div>

    <div class="col-md-3">
        <label class="form-label">Environment</label>
        <select class="form-select" @bind="SelectedEnvironment">
            @foreach (var env in Environments)
            {
                <option value="@env">@env</option>
            }
        </select>
    </div>

    <div class="col-md-3">
        <label class="form-label">Suite</label>
        <select class="form-select" @bind="SelectedSuite">
            @foreach (var suite in Suites)
            {
                <option value="@suite">@suite</option>
            }
        </select>
    </div>

</div>

<div class="mt-4">
    <button class="btn btn-primary" @onclick="RunTestsAsync" disabled="@IsRunning">
        @if (IsRunning)
        {
            <span class="spinner-border spinner-border-sm me-2"></span>
            <text>Running…</text>
        }
        else
        {
            <span>Run Tests</span>
        }
    </button>
    <button class="btn btn-danger ms-2" @onclick="StopTests" disabled="@(!IsRunning)">
        Stop
    </button>

</div>

<div class="mt-4">
    <h5>Output</h5>
    <pre id="output-panel" class="bg-dark text-light p-3 rounded" style="height: 750px; overflow-y: auto;">
        @string.Join("\n", OutputLines)
    </pre>
</div>

@code {
    // Dropdown data
    private List<string> Browsers = new() { "chromium", "firefox", "webkit" };
    @* private List<string> Headed = new() { "Yes", "No" }; *@
    private List<string> Devices = new() { "Desktop", "Mobile", "Tablet Horizontal", "Tablet Vertical" };
    private List<string> Environments = new() { "DEV", "QA", "REL", "UAT", "PROD" };
    private List<string> Suites = new() { "Smoke", "Regression", "Full" };

    // Selected values
    private string SelectedBrowser = "chromium";
    @* private string SelectedHeaded = "No"; *@
    private string SelectedDevice = "Desktop";
    private string SelectedEnvironment = "REL";
    private string SelectedSuite = "Smoke";

    // Output + state
    private readonly List<string> OutputLines = new();
    private const int MaxLines = 2000;
    private bool IsRunning = false;

    [Inject] private ITestRunnerService TestRunnerService { get; set; } = default!;
    private CancellationTokenSource? cts;
    private async Task RunTestsAsync()
    {
        IsRunning = true;
        OutputLines.Clear();
        cts = new CancellationTokenSource();

        var request = new TestRunRequest(
            SelectedBrowser,
            SelectedDevice,
            SelectedEnvironment,
            SelectedSuite,
            Headed: true
        );

        try
        {
            await foreach (var line in TestRunnerService.RunTestsAsync(request, cts.Token))
            {
                OutputLines.Add(line);
                if (OutputLines.Count > MaxLines)
                    OutputLines.RemoveAt(0);
                await InvokeAsync(StateHasChanged);
                await JS.InvokeVoidAsync("scrollToBottom", "output-panel");
                await Task.Yield();
            }
        }
        catch (OperationCanceledException)
        {
            OutputLines.Add("--- Test run cancelled ---");
        }
        catch (Exception ex)
        {
            OutputLines.Add($"[ERROR] {ex.Message}");
        }
        finally
        {
            IsRunning = false;
            cts?.Dispose();
            cts = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void StopTests()
    {
        cts?.Cancel();
    }
}
