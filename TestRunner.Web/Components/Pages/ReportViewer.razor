@using TestRunner.Web.Services

@page "/reports/view/{RunId}/{FileName}"
@rendermode InteractiveServer

@if (_notFound)
{
    <div class="container mt-5">
        <h4>Report not found</h4>
        <p class="text-muted">The report <code>@FileName</code> in run <code>@RunId</code> could not be located.</p>
        <a href="/reports" class="btn btn-outline-secondary btn-sm">← Back to Reports</a>
    </div>
}
else if (_htmlContent == null)
{
    <p class="text-muted p-4">Loading report...</p>
}
else
{
    @((MarkupString)_htmlContent)
}

@code {
    [Parameter] public string RunId   { get; set; } = "";
    [Parameter] public string FileName { get; set; } = "";
    [Inject] private IReportService ReportService { get; set; } = default!;

    private string? _htmlContent;
    private bool    _notFound;

    protected override async Task OnInitializedAsync()
    {
        // Basic path traversal guard
        if (RunId.Contains('/') || RunId.Contains('\\') ||
            FileName.Contains('/') || FileName.Contains('\\') ||
            !FileName.EndsWith(".html"))
        {
            _notFound = true;
            return;
        }

        var path = Path.Combine(ReportService.GetReportsDirectory(), RunId, FileName);

        if (!File.Exists(path))
        {
            _notFound = true;
            return;
        }

        _htmlContent = await File.ReadAllTextAsync(path);
    }
}
