{
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.feature": "${capture}.feature.cs"
  },
  "files.exclude": {
    "**/obj/": true,
    "**/bin/": true
  },
  "cucumber.glue": [
    "**/**/*.cs"
  ],
  "cucumber.features": [
    "**/**/*.feature"
  ]
}